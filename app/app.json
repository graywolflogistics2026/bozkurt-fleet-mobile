{
  "expo": {
    "name": "Bozkurt Fleet OS",
    "slug": "bozkurt-fleet-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bozkurtfleetos",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["instagram", "fb", "twitter", "linkedin", "tiktok", "snssdk1233"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f1117"
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Bozkurt Fleet OS uses your camera to photograph settlements, receipts, and maintenance invoices for AI-assisted import."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Bozkurt Fleet OS accesses your photo library so you can import a saved photo of a settlement, receipt, or invoice."
        }
      ],
      "expo-localization",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
